# Supabase — copy this file to `.env.local` and fill in the values from your
# Supabase project (dashboard → Connect → App Frameworks → Next.js, or
# Project Settings → API Keys).
#
# `.env.local` is gitignored (never committed). This `.example` file IS
# committed so anyone cloning the repo knows which variables to set.

# Project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...) — safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
